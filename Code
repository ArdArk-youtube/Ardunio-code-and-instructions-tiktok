#include <Wire.h>
#include <Adafruit_PWMServoDriver.h>

Adafruit_PWMServoDriver pwm = Adafruit_PWMServoDriver();

#define SERVOMIN 200
#define SERVOMAX 600

void setup() {
  pwm.begin();
  pwm.setPWMFreq(60);
}

void loop() {
  for (int i = 0; i < 4; i++) {
    pwm.setPWM(i, 0, SERVOMAX);
  }
  delay(500);
  for (int i = 0; i < 4; i++) {
    pwm.setPWM(i, 0, SERVOMIN);
  }
  delay(500);
  
}
